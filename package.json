{
  "name": "bserc-email-server",
  "version": "0.1.0",
  "description": "Bulk email notification platform powered by AWS SES + SQS + SNS",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "migrate": "tsx src/scripts/migrate.ts",
    "seed:admin": "tsx src/scripts/seed-admin.ts",
    "infra:setup": "tsx src/scripts/aws-setup.ts",
    "lint": "tsc --noEmit",
    "test": "TEST_NO_AWS=true NODE_ENV=test ALLOW_RAW_QUERY=false tsx --test --test-concurrency=1 --test-reporter=spec tests/**/*.test.ts",
    "seed:test-data": "tsx src/scripts/seed-test-data.ts",
    "perf": "TEST_NO_AWS=true NODE_ENV=test LOG_LEVEL=error tsx src/scripts/perf.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.668.0",
    "@aws-sdk/client-sns": "^3.668.0",
    "@aws-sdk/client-sqs": "^3.668.0",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.3",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}

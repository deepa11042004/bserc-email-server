# --- Server ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# --- Auth ---
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=12h

# --- Source DB (read-only for recipients) ---
SOURCE_DB_HOST=bserc-central-db.example.rds.amazonaws.com
SOURCE_DB_PORT=3306
SOURCE_DB_USER=admin
SOURCE_DB_PASSWORD=
SOURCE_DB_NAME=bserc_core_db

# --- Email Notification DB (this app's own schema) ---
APP_DB_HOST=bserc-central-db.example.rds.amazonaws.com
APP_DB_PORT=3306
APP_DB_USER=admin
APP_DB_PASSWORD=
APP_DB_NAME=email_notification_db

# --- AWS ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SES
SES_DEFAULT_FROM_EMAIL=hr@yourcompany.com
SES_CONFIGURATION_SET=email-notification-cs
SES_MAX_SEND_RATE_PER_SEC=14

# SQS
SQS_QUEUE_NAME=email-notification-jobs
SQS_DLQ_NAME=email-notification-jobs-dlq
SQS_QUEUE_URL=
SQS_DLQ_URL=

# SNS (webhook notifications from SES)
SNS_TOPIC_NAME=email-notification-events
SNS_TOPIC_ARN=

# --- Worker tuning ---
WORKER_CONCURRENCY=10
WORKER_BATCH_SIZE=10
WORKER_VISIBILITY_TIMEOUT_SEC=120

# --- Recipient sourcing safety ---
ALLOWED_RECIPIENT_TABLES=crm_leads,users,candidates
ALLOW_RAW_QUERY=false

# --- Webhook (public-facing) ---
WEBHOOK_PATH=/api/webhooks/ses
